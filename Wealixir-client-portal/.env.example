# ============================================================
# Wealixir Client Portal — environment variables template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Session security ─────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# ── Email / SMTP ─────────────────────────────────────────────
# Set false to run without email — OTP is returned in the API response instead
MAIL_ENABLED=false
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@example.com
# For Gmail use an App Password, not your login password
MAIL_PASSWORD=your-app-password-here
MAIL_FROM=your-email@example.com

# ── Microsoft OneDrive (Azure App Registration) ───────────────
# Leave all blank to disable OneDrive sync
ONEDRIVE_TENANT_ID=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_DRIVE_ID=
ONEDRIVE_FOLDER_NAME=Wealixir Registrations
